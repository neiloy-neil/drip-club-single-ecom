generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

// User.id mirrors the Supabase auth.users.id (UUID) — assigned explicitly at
// signup time, not auto-generated, so it stays in sync with auth.users.
model User {
  id        String   @id
  name      String?
  email     String   @unique
  image     String?
  phone     String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses         Address[]
  orders            Order[]
  loyaltyPoints     LoyaltyPoint[]
  reviews           Review[]
  customerTags      CustomerTag[]
  wishlists         WishlistItem[]
  storeCredits      StoreCredit[]
  storeCreditTxns   StoreCreditTransaction[]

  @@map("users")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

// ─────────────────────────────────────────────
// ADDRESS
// ─────────────────────────────────────────────

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String  @default("Home") // Home, Office, etc.
  fullName   String
  phone      String
  division   String
  district   String
  area       String
  address    String
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ─────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  parent          Category?               @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[]              @relation("CategoryTree")
  products        Product[]
  flashSales      FlashSale[]
  attributeConfig CategoryAttributeConfig?
  sizeGuide       SizeGuide?
  couponRules     CouponRule[]

  @@map("categories")
}

// Controls the display labels for "size" and "color" variant attributes per category.
// A gadget category admin sets attr1Label="Storage" attr2Label="Color".
// No schema change needed per vertical — just re-label the existing columns.
model CategoryAttributeConfig {
  id         String   @id @default(cuid())
  categoryId String   @unique
  attr1Label String   @default("Size")   // maps to ProductVariant.size
  attr2Label String   @default("Color")  // maps to ProductVariant.color
  attr1Hint  String?  // e.g. "S, M, L, XL" or "128GB, 256GB, 512GB"
  attr2Hint  String?  // e.g. "Red, Blue, Black" or "Midnight Black"

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("category_attribute_configs")
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal
  comparePrice Decimal?
  categoryId  String
  brandId     String?
  tags        String?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  isDigital   Boolean  @default(false)
  downloadLimit     Int?
  downloadExpireHours Int?
  minQty      Int?     // minimum order quantity
  maxQty      Int?     // maximum per order
  stepQty     Int?     // must buy in multiples of stepQty
  weight      Decimal? // grams, for shipping rate lookup
  metaTitle     String?
  metaDescription String?
  ogImage       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       Category         @relation(fields: [categoryId], references: [id])
  brand          Brand?           @relation(fields: [brandId], references: [id])
  images         ProductImage[]
  variants       ProductVariant[]
  orderItems     OrderItem[]
  reviews        Review[]
  flashSales     FlashSale[]
  digitalAssets  DigitalAsset[]
  bundleItems    BundleItem[]
  blogPosts      BlogPostProduct[]
  wishlists      WishlistItem[]
  addons              ProductAddon[]
  orderBumps          OrderBump[]
  reviewQAs           ReviewQA[]
  priceRules          PriceRule[]
  subscriptionPlans   SubscriptionPlan[]
  frequentlyBoughtTogether FrequentlyBoughtTogether[] @relation("FBTSource")
  fbtRelated               FrequentlyBoughtTogether[] @relation("FBTRelated")
  productTags    ProductTag[]     @relation("ProductTags")

  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  videoUrl  String?
  isVideo   Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  size      String
  color     String
  colorHex  String?
  sku       String  @unique
  stock     Int     @default(0)
  price     Decimal?
  costPrice Decimal @default(0)
  minQty    Int?    // variant-level override
  maxQty    Int?

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
  cartItems          CartItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockAlerts        StockAlert[]
  locationStock      LocationStock[]

  @@map("product_variants")
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  sessionId String?    @unique // for guest carts
  userId    String?    @unique // for logged-in carts
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique // e.g. ORD-2024-0001
  userId          String?
  addressId       String?
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(UNPAID)
  subtotal        Decimal
  discount        Decimal       @default(0)
  shippingCharge  Decimal       @default(0)
  total           Decimal
  couponId        String?
  note            String?       // customer note / special instructions
  giftMessage     String?
  giftWrap        Boolean       @default(false)
  giftWrapCharge  Decimal       @default(0)
  deliveryDate    DateTime?
  depositAmount   Decimal       @default(0)
  customFields    Json?         // answers to admin-defined CheckoutFields
  depositPaid     Boolean       @default(false)
  isGuest         Boolean       @default(false)
  guestEmail      String?
  codCallNote     String?       // admin call log for COD verification
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Shipping snapshot (in case address changes later)
  shippingName    String
  shippingPhone   String
  shippingAddress String
  shippingArea    String
  shippingDistrict String
  shippingDivision String

  tags        String[]       @default([])

  user        User?          @relation(fields: [userId], references: [id])
  address     Address?       @relation(fields: [addressId], references: [id])
  coupon      Coupon?        @relation(fields: [couponId], references: [id])
  items       OrderItem[]
  payment     Payment?
  delivery    Delivery?
  shipments   OrderShipment[]
  statusLogs  OrderStatusLog[]
  returnRequests ReturnRequest[]
  affiliateConversions AffiliateConversion[]
  messages    OrderMessage[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String
  quantity  Int
  price     Decimal  // price at time of order
  productName String // snapshot
  size      String
  color     String

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
  shipmentItems     OrderShipmentItem[]
  returnItems       ReturnItem[]
  digitalDownloads  DigitalDownload[]

  @@map("order_items")
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_logs")
}

enum OrderStatus {
  DRAFT         // draft order / quote
  PENDING       // just placed
  CONFIRMED     // admin confirmed
  PACKED        // ready to ship
  SHIPPED       // handed to courier
  DELIVERED     // delivered to customer
  CANCELLED     // cancelled
  RETURNED      // returned by customer
}

enum PaymentMethod {
  BKASH
  NAGAD
  COD
}

enum PaymentStatus {
  UNPAID
  PARTIAL  // deposit paid, remainder due on delivery (COD)
  PAID
  REFUNDED
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          PaymentMethod
  status          PaymentStatus @default(UNPAID)
  amount          Decimal       
  transactionId   String?       // bKash/Nagad trxID
  gatewayResponse Json?         // raw response from gateway
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// DELIVERY
// ─────────────────────────────────────────────

model Delivery {
  id             String         @id @default(cuid())
  orderId        String         @unique
  courier        CourierService
  consignmentId  String?        // Pathao/Steadfast ID
  trackingCode   String?
  status         DeliveryStatus @default(PENDING)
  charge         Decimal         @default(0)
  estimatedDate  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("deliveries")
}

enum CourierService {
  PATHAO
  STEADFAST
  SELF
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

// ─────────────────────────────────────────────
// COUPONS & DISCOUNTS
// ─────────────────────────────────────────────

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  type          DiscountType // PERCENTAGE or FLAT
  value         Decimal      
  minOrderAmount Decimal?    
  maxUses       Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())

  orders Order[]
  rule   CouponRule?

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

// ─────────────────────────────────────────────
// SUPPLIERS & PURCHASE ORDERS
// ─────────────────────────────────────────────

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  poNumber   String              @unique // e.g. PO-2026-0001
  supplierId String
  status     PurchaseOrderStatus @default(PENDING)
  totalCost  Decimal             @default(0)
  note       String?
  createdAt  DateTime            @default(now())
  receivedAt DateTime?

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  variantId       String
  quantity        Int
  costPrice       Decimal // cost per unit at time of order

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@map("purchase_order_items")
}

enum PurchaseOrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

// ─────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────

model Expense {
  id        String   @id @default(cuid())
  category  String // Rent, Utilities, Salaries, Marketing, Other, etc.
  amount    Decimal
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  @@map("expenses")
}

// ─────────────────────────────────────────────
// LOYALTY POINTS
// ─────────────────────────────────────────────

model LoyaltyPoint {
  id          String            @id @default(cuid())
  userId      String
  points      Int               // positive = earned, negative = redeemed
  type        LoyaltyPointType
  description String?
  orderId     String?
  createdAt   DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loyalty_points")
}

enum LoyaltyPointType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED  // manual admin adjustment
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  rating     Int
  comment    String?
  isApproved Boolean  @default(false)
  helpful    Int      @default(0) // upvote count
  createdAt  DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id])
  product Product       @relation(fields: [productId], references: [id])
  media   ReviewMedia[]

  @@unique([userId, productId])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// AUTOMATIC DISCOUNTS (bulk / tiered)
// ─────────────────────────────────────────────

// Applied automatically at checkout — no coupon code needed.
// Rule types:
//   BUY_X_GET_PERCENT   — buy X+ units of same product → get Y% off
//   SPEND_X_GET_PERCENT — cart subtotal >= X → get Y% off
//   BUY_X_ITEMS_GET_PERCENT — any X+ items in cart → get Y% off
model AutoDiscount {
  id            String           @id @default(cuid())
  name          String
  ruleType      AutoDiscountRule
  thresholdQty  Int?             // used by BUY_X rules
  thresholdAmt  Decimal?         // used by SPEND_X rule
  discountPct   Decimal          // percentage discount to apply
  isActive      Boolean          @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime         @default(now())

  @@map("auto_discounts")
}

enum AutoDiscountRule {
  BUY_X_GET_PERCENT
  SPEND_X_GET_PERCENT
  BUY_X_ITEMS_GET_PERCENT
}

// ─────────────────────────────────────────────
// FLASH SALES
// ─────────────────────────────────────────────

model FlashSale {
  id            String       @id @default(cuid())
  name          String       // e.g. "Eid Mega Sale"
  discountType  DiscountType // PERCENTAGE or FLAT
  discountValue Decimal
  scope         FlashSaleScope @default(SITEWIDE)
  productId     String?      // if scope=PRODUCT
  categoryId    String?      // if scope=CATEGORY
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  product  Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("flash_sales")
}

enum FlashSaleScope {
  SITEWIDE
  CATEGORY
  PRODUCT
}

// ─────────────────────────────────────────────
// BACK-IN-STOCK ALERTS
// ─────────────────────────────────────────────

model StockAlert {
  id        String   @id @default(cuid())
  email     String
  variantId String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([email, variantId])
  @@map("stock_alerts")
}

// ─────────────────────────────────────────────
// BANNERS & SETTINGS
// ─────────────────────────────────────────────

model Banner {
  id        String   @id @default(cuid())
  title     String?
  image     String
  link      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("banners")
}

// Admin-editable content pages (FAQ, Returns, Size Guide, Contact, etc.)
// so these don't need a code change per store.
model Page {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "faq", "returns", "size-guide", "contact"
  title       String
  content     String // simple HTML, rendered as-is
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pages")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
  // Keys: store_name, store_logo, currency, points_per_taka,
  //       points_redemption_rate, free_shipping_above,
  //       bkash_merchant_number, nagad_merchant_number
}

// ─────────────────────────────────────────────
// SHIPPING ZONES
// ─────────────────────────────────────────────

model ShippingZone {
  id                 String   @id @default(cuid())
  name               String   // "Dhaka City", "Chittagong", "Rest of BD"
  districts          String   // comma-separated district names
  charge             Decimal  @default(0)
  freeShippingAbove  Decimal? // override global free_shipping_above for this zone
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())

  rates ShippingRate[]

  @@map("shipping_zones")
}

// ─────────────────────────────────────────────
// PRODUCT BUNDLES
// ─────────────────────────────────────────────

model Bundle {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  price       Decimal    // bundle price (usually less than sum of parts)
  comparePrice Decimal?
  image       String?
  isActive    Boolean    @default(true)
  type        BundleType @default(FIXED)
  minItems    Int?       // for PICK_N type: minimum items customer must pick
  maxItems    Int?       // for PICK_N type: maximum items customer can pick
  discountPct Decimal?   // % off for PICK_N bundles
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  items BundleItem[]

  @@map("bundles")
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  productId String
  quantity  Int     @default(1)
  sortOrder Int     @default(0)

  bundle  Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("bundle_items")
}

enum BundleType {
  FIXED    // fixed set of products at a fixed price
  PICK_N   // customer picks N from a list, gets % off
}

// ─────────────────────────────────────────────
// DIGITAL ASSETS
// ─────────────────────────────────────────────

model DigitalAsset {
  id        String  @id @default(cuid())
  productId String
  name      String
  storagePath String  // Supabase Storage path
  fileSize  Int?    // bytes
  mimeType  String?
  sortOrder Int     @default(0)

  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  downloads DigitalDownload[]

  @@map("digital_assets")
}

model DigitalDownload {
  id           String    @id @default(cuid())
  assetId      String
  orderItemId  String
  userId       String?
  guestEmail   String?
  downloadCount Int     @default(0)
  maxDownloads  Int?    // null = unlimited
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  asset     DigitalAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  orderItem OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("digital_downloads")
}

// ─────────────────────────────────────────────
// ORDER SHIPMENTS (partial fulfilment)
// ─────────────────────────────────────────────

model OrderShipment {
  id            String         @id @default(cuid())
  orderId       String
  shipmentNumber Int           // 1, 2, 3…
  courier        CourierService
  consignmentId  String?
  trackingCode   String?
  status         DeliveryStatus @default(PENDING)
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items OrderShipmentItem[]

  @@map("order_shipments")
}

model OrderShipmentItem {
  id         String @id @default(cuid())
  shipmentId String
  orderItemId String
  quantity   Int

  shipment  OrderShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItem OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_shipment_items")
}

// ─────────────────────────────────────────────
// RETURNS / RMA
// ─────────────────────────────────────────────

model ReturnRequest {
  id          String       @id @default(cuid())
  orderId     String
  userId      String?
  guestEmail  String?
  reason      ReturnReason
  note        String?
  photos      String[]     // Supabase Storage URLs
  status      ReturnStatus @default(PENDING)
  refundAmount Decimal?
  adminNote   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  order Order        @relation(fields: [orderId], references: [id])
  items ReturnItem[]

  @@map("return_requests")
}

model ReturnItem {
  id              String @id @default(cuid())
  returnRequestId String
  orderItemId     String
  quantity        Int

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id])

  @@map("return_items")
}

enum ReturnReason {
  WRONG_SIZE
  DEFECTIVE
  WRONG_ITEM
  CHANGED_MIND
  QUALITY_ISSUE
  OTHER
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  RECEIVED
}

// ─────────────────────────────────────────────
// ABANDONED CARTS
// ─────────────────────────────────────────────

model AbandonedCart {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  email       String?
  name        String?
  phone       String?
  items       Json     // snapshot of cart items
  subtotal    Decimal
  recoveredAt DateTime?
  isRecovered Boolean  @default(false)
  orderId     String?
  emailSent   Boolean  @default(false)
  emailSentAt DateTime?
  email1SentAt DateTime?
  email2SentAt DateTime?
  email3SentAt DateTime?
  couponCode  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("abandoned_carts")
}

// ─────────────────────────────────────────────
// AFFILIATES & REFERRALS
// ─────────────────────────────────────────────

model Affiliate {
  id           String          @id @default(cuid())
  userId       String?         // null if non-user affiliate
  name         String
  email        String          @unique
  code         String          @unique // ref code in URL ?ref=CODE
  commissionType DiscountType  @default(PERCENTAGE)
  commissionValue Decimal      @default(10)
  totalEarned  Decimal         @default(0)
  totalPaid    Decimal         @default(0)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())

  clicks      AffiliateClick[]
  conversions AffiliateConversion[]

  @@map("affiliates")
}

model AffiliateClick {
  id          String   @id @default(cuid())
  affiliateId String
  ip          String?
  userAgent   String?
  landingPage String?
  createdAt   DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("affiliate_clicks")
}

model AffiliateConversion {
  id            String    @id @default(cuid())
  affiliateId   String
  orderId       String
  orderTotal    Decimal
  commission    Decimal
  isPaid        Boolean   @default(false)
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  order     Order     @relation(fields: [orderId], references: [id])

  @@map("affiliate_conversions")
}

// ─────────────────────────────────────────────
// CUSTOMER SEGMENTS & TAGS
// ─────────────────────────────────────────────

model CustomerTag {
  id     String @id @default(cuid())
  userId String
  tag    String // "VIP", "At Risk", "New", "Loyal", custom tags

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tag])
  @@map("customer_tags")
}

// ─────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────

model BlogCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  authorName  String    @default("Admin")
  categoryId  String?
  tags        String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category BlogCategory?    @relation(fields: [categoryId], references: [id])
  products BlogPostProduct[]

  @@map("blog_posts")
}

model BlogPostProduct {
  id        String @id @default(cuid())
  postId    String
  productId String

  post    BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([postId, productId])
  @@map("blog_post_products")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  // userId (null = system/guest)
  actorEmail String?
  actorRole  String?
  action     String   // "order.status_changed", "product.updated", "settings.updated"
  entityType String   // "Order", "Product", "Setting", etc.
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// SIZE GUIDE (per category)
// ─────────────────────────────────────────────

model SizeGuide {
  id         String @id @default(cuid())
  categoryId String @unique
  unit       String @default("cm")   // "cm" or "inches"
  columns    Json   // ["Size", "Chest", "Waist", "Hip", "Length"]
  rows       Json   // [["S", "86-90", "70-74", "90-94", "65"], ...]
  notes      String?

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("size_guides")
}

// ─────────────────────────────────────────────
// WORKFLOW ENGINE (D4)
// ─────────────────────────────────────────────

enum WorkflowTrigger {
  ORDER_PLACED
  ORDER_STATUS_CHANGED
  PAYMENT_RECEIVED
  REVIEW_LEFT
  CUSTOMER_REGISTERED
  ABANDONED_CART
  RETURN_APPROVED
}

enum WorkflowActionType {
  SEND_EMAIL
  ADD_TAG
  REMOVE_TAG
  APPLY_COUPON
  NOTIFY_ADMIN
  ADD_STORE_CREDIT
}

model Workflow {
  id          String          @id @default(cuid())
  name        String
  description String?
  trigger     WorkflowTrigger
  conditions  Json            @default("[]") // [{field, operator, value}]
  actions     Json            @default("[]") // [{type, config}]
  isActive    Boolean         @default(true)
  runCount    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  runs        WorkflowRun[]

  @@map("workflows")
}

model WorkflowRun {
  id         String   @id @default(cuid())
  workflowId String
  entityId   String   // orderId, userId, etc.
  entityType String
  status     String   @default("SUCCESS") // SUCCESS | FAILED | SKIPPED
  log        String?
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([entityId])
  @@map("workflow_runs")
}

// ─────────────────────────────────────────────
// SHIPPING TABLE RATES (D7)
// ─────────────────────────────────────────────

model ShippingRate {
  id          String   @id @default(cuid())
  zoneId      String
  label       String   // "0–500g", "1–3 items"
  minWeight   Decimal? // grams
  maxWeight   Decimal? // grams
  minQty      Int?
  maxQty      Int?
  rate        Decimal
  createdAt   DateTime @default(now())

  zone ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("shipping_rates")
}

// ─────────────────────────────────────────────
// DELIVERY SCHEDULE (D8)
// ─────────────────────────────────────────────

model DeliverySchedule {
  id           String   @id @default(cuid())
  district     String?  // null = global default
  leadDays     Int      @default(2)    // min days before delivery
  cutoffHour   Int      @default(14)   // orders after 2pm = +1 day
  blackoutDates Json    @default("[]") // ["2025-12-25","2026-01-01"]
  workingDays  Json     @default("[1,2,3,4,5,6]") // 0=Sun..6=Sat
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([district])
  @@map("delivery_schedules")
}

// ─────────────────────────────────────────────
// GIFT CARDS (D10)
// ─────────────────────────────────────────────

model GiftCard {
  id            String    @id @default(cuid())
  code          String    @unique
  amount        Decimal
  balance       Decimal
  senderName    String?
  senderEmail   String?
  recipientEmail String
  message       String?
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  redeemedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions GiftCardTransaction[]

  @@map("gift_cards")
}

model GiftCardTransaction {
  id         String   @id @default(cuid())
  giftCardId String
  orderId    String?
  amount     Decimal
  type       String   // REDEEM | REFUND
  createdAt  DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@map("gift_card_transactions")
}

// ─────────────────────────────────────────────
// STORE CREDIT (D11)
// ─────────────────────────────────────────────

model StoreCredit {
  id        String   @id @default(cuid())
  userId    String
  balance   Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions StoreCreditTransaction[]

  @@unique([userId])
  @@map("store_credits")
}

model StoreCreditTransaction {
  id            String   @id @default(cuid())
  userId        String
  storeCreditId String?
  amount        Decimal
  type          String   // CREDIT | DEBIT
  reason        String?
  orderId       String?
  issuedBy      String?  // admin userId
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeCredit StoreCredit? @relation(fields: [storeCreditId], references: [id])

  @@index([userId])
  @@map("store_credit_transactions")
}

// ─────────────────────────────────────────────
// WISHLIST (D/E7)
// ─────────────────────────────────────────────

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?  // for guests
  productId String
  variantId String?
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([sessionId])
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────
// MAILCHIMP / KLAVIYO SYNC (D3)
// ─────────────────────────────────────────────

model MarketingSubscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  provider   String
  listId     String?
  status     String   @default("subscribed")
  syncedAt   DateTime?
  tags       Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("marketing_subscribers")
}

// ─────────────────────────────────────────────
// BRANDS (E2)
// ─────────────────────────────────────────────

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  logo        String?
  banner      String?
  description String?
  website     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@map("brands")
}

// ─────────────────────────────────────────────
// PRODUCT ADD-ONS (E1)
// ─────────────────────────────────────────────

enum AddonType {
  TEXT
  TEXTAREA
  SELECT
  CHECKBOX
  COLOR
  FILE
}

model ProductAddon {
  id            String    @id @default(cuid())
  productId     String
  label         String
  type          AddonType @default(TEXT)
  options       Json      @default("[]") // [{label, value, hex?, priceModifier}]
  priceModifier Decimal   @default(0)    // flat add to price for non-SELECT types
  isRequired    Boolean   @default(false)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_addons")
}

// ─────────────────────────────────────────────
// DYNAMIC / ROLE-BASED PRICING (E4)
// ─────────────────────────────────────────────

enum PriceRuleType {
  TAG_DISCOUNT      // customer has tag X → get Y% off
  QTY_TIER          // buy N+ units → get Y% off
  MEMBER_PRICE      // membership plan members get flat price
}

model PriceRule {
  id            String        @id @default(cuid())
  name          String
  type          PriceRuleType
  productId     String?       // null = applies sitewide
  tagName       String?       // for TAG_DISCOUNT
  minQty        Int?          // for QTY_TIER
  discountType  DiscountType  @default(PERCENTAGE)
  discountValue Decimal
  isActive      Boolean       @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime      @default(now())

  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("price_rules")
}

// ─────────────────────────────────────────────
// ORDER BUMPS / UPSELLS (E5)
// ─────────────────────────────────────────────

model OrderBump {
  id               String   @id @default(cuid())
  productId        String
  headline         String   // "Add matching socks for only ৳150!"
  description      String?
  discountPct      Decimal  @default(0)
  triggerMinTotal  Decimal? // show only when cart >= this amount
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_bumps")
}

// ─────────────────────────────────────────────
// CHECKOUT CUSTOM FIELDS (E6)
// ─────────────────────────────────────────────

enum CheckoutFieldType {
  TEXT
  TEXTAREA
  SELECT
  CHECKBOX
  DATE
}

model CheckoutField {
  id          String            @id @default(cuid())
  label       String
  placeholder String?
  type        CheckoutFieldType @default(TEXT)
  options     Json              @default("[]") // for SELECT type
  isRequired  Boolean           @default(false)
  step        Int               @default(1) // checkout step to show on
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())

  @@map("checkout_fields")
}

// ─────────────────────────────────────────────
// REVIEW MEDIA & Q&A (E8)
// ─────────────────────────────────────────────

model ReviewMedia {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  type      String   @default("IMAGE") // IMAGE | VIDEO
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_media")
}

model ReviewQA {
  id          String   @id @default(cuid())
  productId   String
  userId      String?
  guestName   String?
  guestEmail  String?
  question    String
  answer      String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  answeredAt  DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("review_qas")
}

// ─────────────────────────────────────────────
// MEMBERSHIPS (E11)
// ─────────────────────────────────────────────

enum MembershipBillingCycle {
  MONTHLY
  YEARLY
  LIFETIME
}

model MembershipPlan {
  id               String                 @id @default(cuid())
  name             String
  slug             String                 @unique
  description      String?
  price            Decimal
  billingCycle     MembershipBillingCycle @default(MONTHLY)
  discountPct      Decimal                @default(0)  // % off all products
  freeShipping     Boolean                @default(false)
  exclusiveAccess  Boolean                @default(false)
  benefits         Json                   @default("[]") // ["Free shipping", "10% off", ...]
  isActive         Boolean                @default(true)
  sortOrder        Int                    @default(0)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  subscriptions MembershipSubscription[]

  @@map("membership_plans")
}

model MembershipSubscription {
  id        String    @id @default(cuid())
  userId    String
  planId    String
  status    String    @default("ACTIVE") // ACTIVE | CANCELLED | EXPIRED
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  cancelledAt DateTime?
  autoRenew Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  plan MembershipPlan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@map("membership_subscriptions")
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS / RECURRING ORDERS (F1)
// ─────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  productId     String
  name          String   // "Weekly Coffee Replenishment"
  intervalDays  Int      @default(30)  // frequency in days
  discountPct   Decimal  @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  planId          String
  variantId       String?
  quantity        Int                @default(1)
  status          SubscriptionStatus @default(ACTIVE)
  nextOrderAt     DateTime
  lastOrderId     String?
  addressId       String?
  paymentMethod   PaymentMethod      @default(COD)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([nextOrderAt])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// BOOKINGS / APPOINTMENTS (F2)
// ─────────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model BookingService {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  price        Decimal
  durationMins Int      @default(60)
  maxSlots     Int      @default(1) // per time slot
  isActive     Boolean  @default(true)
  images       Json     @default("[]") // url array
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings     Booking[]

  @@map("booking_services")
}

model Booking {
  id          String        @id @default(cuid())
  serviceId   String
  userId      String?
  guestName   String?
  guestEmail  String?
  guestPhone  String?
  bookingDate DateTime
  status      BookingStatus @default(PENDING)
  note        String?
  adminNote   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  service BookingService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([bookingDate])
  @@index([userId])
  @@map("bookings")
}

// ─────────────────────────────────────────────
// PRODUCT VIEWS / ANALYTICS (F4)
// ─────────────────────────────────────────────

model ProductView {
  id        String   @id @default(cuid())
  productId String
  sessionId String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
  @@map("product_views")
}

// ─────────────────────────────────────────────
// ADVANCED COUPONS (F7) — extend existing Coupon
// ─────────────────────────────────────────────
// Extended fields are added via CouponRule which stores BOGO / category / stacking config

model CouponRule {
  id              String   @id @default(cuid())
  couponId        String   @unique
  ruleType        String   // BOGO | CATEGORY_RESTRICT | MIN_ITEMS | FREE_SHIPPING
  buyQty          Int?     // BOGO: buy this many
  getQty          Int?     // BOGO: get this many free
  categoryId      String?  // CATEGORY_RESTRICT: only applies to this category
  minItems        Int?     // MIN_ITEMS: cart must have at least N items
  maxDiscount     Decimal? // cap the discount amount
  isStackable     Boolean  @default(false)
  usagePerUser    Int?     // max uses per customer
  createdAt       DateTime @default(now())

  coupon   Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@map("coupon_rules")
}

// ─────────────────────────────────────────────
// MULTI-LOCATION INVENTORY (F8)
// ─────────────────────────────────────────────

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  stock LocationStock[]

  @@map("locations")
}

model LocationStock {
  id         String @id @default(cuid())
  locationId String
  variantId  String
  stock      Int    @default(0)

  location Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([locationId, variantId])
  @@map("location_stock")
}

// ─────────────────────────────────────────────
// SHIPPING LABELS (F9)
// ─────────────────────────────────────────────

model ShippingLabel {
  id            String   @id @default(cuid())
  orderId       String   @unique
  courier       String   // PATHAO | STEADFAST
  consignmentId String?
  trackingCode  String?
  labelUrl      String?
  barcode       String?
  status        String   @default("PENDING") // PENDING | SUBMITTED | IN_TRANSIT | DELIVERED
  apiResponse   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
  @@map("shipping_labels")
}

// ─────────────────────────────────────────────
// FREQUENTLY BOUGHT TOGETHER (Feature 4)
// ─────────────────────────────────────────────

model FrequentlyBoughtTogether {
  id          String   @id @default(cuid())
  productId   String
  relatedId   String
  sortOrder   Int      @default(0)
  product     Product  @relation("FBTSource", fields: [productId], references: [id], onDelete: Cascade)
  related     Product  @relation("FBTRelated", fields: [relatedId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  @@unique([productId, relatedId])
  @@map("frequently_bought_together")
}

// ─────────────────────────────────────────────
// PRODUCT TAGS & SMART COLLECTIONS (Feature 6)
// ─────────────────────────────────────────────

model ProductTag {
  id        String   @id @default(cuid())
  name      String   @unique
  products  Product[] @relation("ProductTags")

  @@map("product_tags")
}

model SmartCollection {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  rules       Json     // [{ field: "price"|"tag"|"category"|"vendor", operator: "less_than"|"greater_than"|"equals"|"contains", value: string }]
  ruleMatch   String   @default("all") // "all" | "any"
  sortBy      String   @default("created_desc")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("smart_collections")
}

// ─────────────────────────────────────────────
// ORDER MESSAGES (Feature 10)
// ─────────────────────────────────────────────

model OrderMessage {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromAdmin Boolean  @default(false)
  message   String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@map("order_messages")
}

// ─────────────────────────────────────────────
// SEARCH ANALYTICS (Feature 12)
// ─────────────────────────────────────────────

model SearchAnalytic {
  id          String   @id @default(cuid())
  query       String
  resultsCount Int
  clicked     Boolean  @default(false)
  clickedSlug String?
  userId      String?
  sessionId   String?
  createdAt   DateTime @default(now())

  @@index([query])
  @@index([createdAt])
  @@map("search_analytics")
}

// ─────────────────────────────────────────────
// FUNNEL EVENTS (Feature 13)
// ─────────────────────────────────────────────

model FunnelEvent {
  id        String   @id @default(cuid())
  event     String   // "product_view" | "add_to_cart" | "checkout_start" | "checkout_complete"
  productId String?
  orderId   String?
  userId    String?
  sessionId String
  value     Float?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
  @@map("funnel_events")
}

// ─────────────────────────────────────────────
// EMAIL CAMPAIGNS (Feature 14)
// ─────────────────────────────────────────────

model EmailCampaign {
  id            String   @id @default(cuid())
  name          String
  subject       String
  previewText   String?
  bodyHtml      String   @db.Text
  status        String   @default("DRAFT") // DRAFT | SCHEDULED | SENDING | SENT | CANCELLED
  scheduledAt   DateTime?
  sentAt        DateTime?
  recipientType String   @default("ALL") // ALL | CUSTOMERS | VIP | TAG:xxx | MEMBERS
  totalSent     Int      @default(0)
  totalOpened   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("email_campaigns")
}

// ─────────────────────────────────────────────
// SMS LOG (Feature 15)
// ─────────────────────────────────────────────

model SmsLog {
  id        String   @id @default(cuid())
  phone     String
  message   String
  event     String
  status    String   @default("SENT")
  provider  String   @default("twilio")
  createdAt DateTime @default(now())

  @@map("sms_logs")
}

// ─────────────────────────────────────────────
// FBT RELATED (back-reference on Product)
// ─────────────────────────────────────────────
// Note: FBTRelated is handled via FrequentlyBoughtTogether.related relation above

