generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

// User.id mirrors the Supabase auth.users.id (UUID) — assigned explicitly at
// signup time, not auto-generated, so it stays in sync with auth.users.
model User {
  id        String   @id
  name      String?
  email     String   @unique
  image     String?
  phone     String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses     Address[]
  orders        Order[]
  loyaltyPoints LoyaltyPoint[]
  reviews       Review[]

  @@map("users")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

// ─────────────────────────────────────────────
// ADDRESS
// ─────────────────────────────────────────────

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String  @default("Home") // Home, Office, etc.
  fullName   String
  phone      String
  division   String
  district   String
  area       String
  address    String
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ─────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  parent          Category?              @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[]             @relation("CategoryTree")
  products        Product[]
  flashSales      FlashSale[]
  attributeConfig CategoryAttributeConfig?

  @@map("categories")
}

// Controls the display labels for "size" and "color" variant attributes per category.
// A gadget category admin sets attr1Label="Storage" attr2Label="Color".
// No schema change needed per vertical — just re-label the existing columns.
model CategoryAttributeConfig {
  id         String   @id @default(cuid())
  categoryId String   @unique
  attr1Label String   @default("Size")   // maps to ProductVariant.size
  attr2Label String   @default("Color")  // maps to ProductVariant.color
  attr1Hint  String?  // e.g. "S, M, L, XL" or "128GB, 256GB, 512GB"
  attr2Hint  String?  // e.g. "Red, Blue, Black" or "Midnight Black"

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("category_attribute_configs")
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  
  comparePrice Decimal?  // original price for strike-through
  categoryId  String
  tags        String? // e.g. "summer, casual"
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   Category        @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  orderItems OrderItem[]
  reviews    Review[]
  flashSales FlashSale[]

  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  size      String  // S, M, L, XL, XXL
  color     String  // Red, Black, White, etc.
  colorHex  String? // #FF0000
  sku       String  @unique
  stock     Int     @default(0)
  price     Decimal?  // override product price if different
  costPrice Decimal @default(0) // current cost basis, updated when a PO is received

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
  cartItems          CartItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockAlerts        StockAlert[]

  @@map("product_variants")
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  sessionId String?    @unique // for guest carts
  userId    String?    @unique // for logged-in carts
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique // e.g. ORD-2024-0001
  userId          String?
  addressId       String?
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(UNPAID)
  subtotal        Decimal       
  discount        Decimal       @default(0) 
  shippingCharge  Decimal       @default(0) 
  total           Decimal       
  couponId        String?
  note            String?       // customer note
  depositAmount   Decimal       @default(0) // advance payment required to confirm a COD order
  depositPaid     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Shipping snapshot (in case address changes later)
  shippingName    String
  shippingPhone   String
  shippingAddress String
  shippingArea    String
  shippingDistrict String
  shippingDivision String

  user        User?          @relation(fields: [userId], references: [id])
  address     Address?       @relation(fields: [addressId], references: [id])
  coupon      Coupon?        @relation(fields: [couponId], references: [id])
  items       OrderItem[]
  payment     Payment?
  delivery    Delivery?
  statusLogs  OrderStatusLog[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String
  quantity  Int
  price     Decimal  // price at time of order
  productName String // snapshot
  size      String
  color     String

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_logs")
}

enum OrderStatus {
  PENDING       // just placed
  CONFIRMED     // admin confirmed
  PACKED        // ready to ship
  SHIPPED       // handed to courier
  DELIVERED     // delivered to customer
  CANCELLED     // cancelled
  RETURNED      // returned by customer
}

enum PaymentMethod {
  BKASH
  NAGAD
  COD
}

enum PaymentStatus {
  UNPAID
  PARTIAL  // deposit paid, remainder due on delivery (COD)
  PAID
  REFUNDED
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          PaymentMethod
  status          PaymentStatus @default(UNPAID)
  amount          Decimal       
  transactionId   String?       // bKash/Nagad trxID
  gatewayResponse Json?         // raw response from gateway
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// DELIVERY
// ─────────────────────────────────────────────

model Delivery {
  id             String         @id @default(cuid())
  orderId        String         @unique
  courier        CourierService
  consignmentId  String?        // Pathao/Steadfast ID
  trackingCode   String?
  status         DeliveryStatus @default(PENDING)
  charge         Decimal         @default(0)
  estimatedDate  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("deliveries")
}

enum CourierService {
  PATHAO
  STEADFAST
  SELF
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

// ─────────────────────────────────────────────
// COUPONS & DISCOUNTS
// ─────────────────────────────────────────────

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  type          DiscountType // PERCENTAGE or FLAT
  value         Decimal      
  minOrderAmount Decimal?    
  maxUses       Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())

  orders Order[]

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

// ─────────────────────────────────────────────
// SUPPLIERS & PURCHASE ORDERS
// ─────────────────────────────────────────────

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  poNumber   String              @unique // e.g. PO-2026-0001
  supplierId String
  status     PurchaseOrderStatus @default(PENDING)
  totalCost  Decimal             @default(0)
  note       String?
  createdAt  DateTime            @default(now())
  receivedAt DateTime?

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  variantId       String
  quantity        Int
  costPrice       Decimal // cost per unit at time of order

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@map("purchase_order_items")
}

enum PurchaseOrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

// ─────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────

model Expense {
  id        String   @id @default(cuid())
  category  String // Rent, Utilities, Salaries, Marketing, Other, etc.
  amount    Decimal
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  @@map("expenses")
}

// ─────────────────────────────────────────────
// LOYALTY POINTS
// ─────────────────────────────────────────────

model LoyaltyPoint {
  id          String            @id @default(cuid())
  userId      String
  points      Int               // positive = earned, negative = redeemed
  type        LoyaltyPointType
  description String?
  orderId     String?
  createdAt   DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loyalty_points")
}

enum LoyaltyPointType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED  // manual admin adjustment
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int      // 1–5
  comment   String?
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// AUTOMATIC DISCOUNTS (bulk / tiered)
// ─────────────────────────────────────────────

// Applied automatically at checkout — no coupon code needed.
// Rule types:
//   BUY_X_GET_PERCENT   — buy X+ units of same product → get Y% off
//   SPEND_X_GET_PERCENT — cart subtotal >= X → get Y% off
//   BUY_X_ITEMS_GET_PERCENT — any X+ items in cart → get Y% off
model AutoDiscount {
  id            String           @id @default(cuid())
  name          String
  ruleType      AutoDiscountRule
  thresholdQty  Int?             // used by BUY_X rules
  thresholdAmt  Decimal?         // used by SPEND_X rule
  discountPct   Decimal          // percentage discount to apply
  isActive      Boolean          @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime         @default(now())

  @@map("auto_discounts")
}

enum AutoDiscountRule {
  BUY_X_GET_PERCENT
  SPEND_X_GET_PERCENT
  BUY_X_ITEMS_GET_PERCENT
}

// ─────────────────────────────────────────────
// FLASH SALES
// ─────────────────────────────────────────────

model FlashSale {
  id            String       @id @default(cuid())
  name          String       // e.g. "Eid Mega Sale"
  discountType  DiscountType // PERCENTAGE or FLAT
  discountValue Decimal
  scope         FlashSaleScope @default(SITEWIDE)
  productId     String?      // if scope=PRODUCT
  categoryId    String?      // if scope=CATEGORY
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  product  Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("flash_sales")
}

enum FlashSaleScope {
  SITEWIDE
  CATEGORY
  PRODUCT
}

// ─────────────────────────────────────────────
// BACK-IN-STOCK ALERTS
// ─────────────────────────────────────────────

model StockAlert {
  id        String   @id @default(cuid())
  email     String
  variantId String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([email, variantId])
  @@map("stock_alerts")
}

// ─────────────────────────────────────────────
// BANNERS & SETTINGS
// ─────────────────────────────────────────────

model Banner {
  id        String   @id @default(cuid())
  title     String?
  image     String
  link      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("banners")
}

// Admin-editable content pages (FAQ, Returns, Size Guide, Contact, etc.)
// so these don't need a code change per store.
model Page {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "faq", "returns", "size-guide", "contact"
  title       String
  content     String // simple HTML, rendered as-is
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pages")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
  // Keys: store_name, store_logo, currency, points_per_taka,
  //       points_redemption_rate, free_shipping_above,
  //       bkash_merchant_number, nagad_merchant_number
}
